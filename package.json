{
  "name": "pi-code-tool",
  "version": "0.6.1",
  "description": "Code-mode tool for the pi coding agent: a sandboxed Python meta-tool (via @pydantic/monty) that lets the agent write code against host tools and build ephemeral code tools",
  "main": "./dist/index.js",
  "scripts": {
    "test": "vitest run",
    "smoke": "tsx examples/smoke.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "pi-package",
    "pi",
    "python",
    "sandbox",
    "code-mode",
    "monty",
    "code-execution"
  ],
  "author": "Joseph Kern <joseph.a.kern@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@pydantic/monty": "^0.0.18",
    "typebox": "^1.2.8"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pi": {
      "types": "./dist/pi/extension.d.ts",
      "import": "./dist/pi/extension.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "extensions"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.js"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josephkern/pi-code-tool.git"
  },
  "homepage": "https://github.com/josephkern/pi-code-tool#readme",
  "bugs": {
    "url": "https://github.com/josephkern/pi-code-tool/issues"
  }
}
